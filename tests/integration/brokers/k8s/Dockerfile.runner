# Runner image for the K8s API live-integration suite (B.9 / #298).
#
# The runner talks to a k3s API server (k3s = single-binary
# Kubernetes distribution) over its admin kubeconfig.  k3s is the
# right cost/coverage trade — full K8s API, single container, ~5s
# boot, no need for nested Docker (unlike kind).
#
# Image shape is identical to the other seven runners — see
# tests/integration/brokers/README.md for the full rationale.  The
# K8s suite doesn't use any of the optional peer-deps declared in
# tests/integration/brokers/package.json (it speaks to k3s via raw
# node:https), but using the same package.json keeps the Dockerfile
# pattern uniform across all eight suites.

FROM oven/bun:1.3-debian

RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY tests/integration/brokers/package.json ./package.json
RUN bun install --no-progress --ignore-scripts

COPY tsconfig.json ./
COPY src/ src/
COPY tests/ tests/

ENV NODE_ENV=production

CMD ["bun", "tests/integration/brokers/k8s/runner.ts"]
