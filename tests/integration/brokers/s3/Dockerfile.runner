# Runner image for the MinIO/S3 live-integration suite (B.2 / #20).
#
# Identical shape across all eight broker runners — see
# tests/integration/brokers/README.md for the full rationale on the
# dedicated test-package.json.  The CMD is the only per-runner
# diff.

FROM oven/bun:debian

RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Test-only package.json — declares every adapter peer-dep as a
# regular `dependencies` entry.  Same shape an end-user has in
# their own project, so `bun install` runs without any
# --production or peer-dep-promotion gymnastics.
COPY tests/integration/brokers/package.json ./package.json
RUN bun install --no-progress --ignore-scripts

COPY tsconfig.json ./
COPY src/ src/
COPY tests/ tests/

ENV NODE_ENV=production

CMD ["bun", "tests/integration/brokers/s3/runner.ts"]
