# Runner image for the Redis Streams live-integration suite
# (B.7 / refs #296).

FROM oven/bun:debian

RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json bun.lock* tsconfig.json ./

RUN bun install --no-progress --production --ignore-scripts

# `ioredis` is an optional peer dep — used by both RedisCache and
# RedisStreamsActor.  `--no-save` after `--production` was unreliable
# (see S3 Dockerfile); the in-container lockfile mutation is
# harmless — it's a build artifact.
RUN bun add ioredis

COPY src/ src/
COPY tests/ tests/

ENV NODE_ENV=production

CMD ["bun", "tests/integration/brokers/redis-streams/runner.ts"]
