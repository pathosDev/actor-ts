# Runner image for the gRPC live-integration suite (B.8 / Closes #296).
#
# Unlike the other broker suites the "broker" here IS the
# framework's GrpcServerActor — server + client live in the same
# runner against a local echo.proto.  No external broker
# container, hence the single-service compose.
#
# Image shape is identical to the other seven runners — see
# tests/integration/brokers/README.md for the full rationale.

FROM oven/bun:1.3-debian

RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY tests/integration/brokers/package.json ./package.json
RUN bun install --no-progress --ignore-scripts

COPY tsconfig.json ./
COPY src/ src/
COPY tests/ tests/

ENV NODE_ENV=production

CMD ["bun", "tests/integration/brokers/grpc/runner.ts"]
