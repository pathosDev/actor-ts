{
  "name": "actor-ts",
  "version": "0.6.0",
  "description": "An actor-model framework for TypeScript — runs on Bun, Node.js and Deno",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "bunx tsc",
    "watch": "bunx tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:dev": "bunx tsc -p tsconfig.dev.json --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "smoke:bun": "bun tests/smoke/smoke.mjs",
    "smoke:node": "bun run build && ACTOR_TS_SMOKE_USE_DIST=1 node tests/smoke/smoke.mjs",
    "smoke:deno": "bun run build && ACTOR_TS_SMOKE_USE_DIST=1 deno run --allow-read --allow-env tests/smoke/smoke.mjs",
    "smoke": "bun run smoke:bun && bun run smoke:node && bun run smoke:deno",
    "bench": "bun run benchmarks/run-all.ts"
  },
  "keywords": [
    "actor",
    "actor-model",
    "concurrency",
    "cluster",
    "typescript",
    "bun",
    "node",
    "deno"
  ],
  "license": "MIT",
  "devDependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@hono/node-server": "^2.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/bun": "^1.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "hono": "^4.12.15",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "@hono/node-server": "^2.0.0",
    "amqplib": "^0.10.0",
    "better-sqlite3": "^12.9.0",
    "cassandra-driver": "^4.0.0",
    "express": "^4.0.0 || ^5.0.0",
    "fzstd": "^0.1.0",
    "hono": "^4.0.0",
    "ioredis": "^5.4.0",
    "kafkajs": "^2.2.0",
    "memjs": "^1.3.0",
    "mqtt": "^5.0.0",
    "nats": "^2.20.0",
    "typescript": "^5.0.0",
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": { "optional": true },
    "@grpc/grpc-js": { "optional": true },
    "@grpc/proto-loader": { "optional": true },
    "@hono/node-server": { "optional": true },
    "amqplib": { "optional": true },
    "better-sqlite3": { "optional": true },
    "cassandra-driver": { "optional": true },
    "express": { "optional": true },
    "fzstd": { "optional": true },
    "hono": { "optional": true },
    "ioredis": { "optional": true },
    "kafkajs": { "optional": true },
    "memjs": { "optional": true },
    "mqtt": { "optional": true },
    "nats": { "optional": true },
    "ws": { "optional": true }
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fastify": "^5.8.5",
    "ts-pattern": "^5.9.0"
  }
}
