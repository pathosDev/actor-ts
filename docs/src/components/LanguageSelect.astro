---
/**
 * Custom LanguageSelect — replaces Starlight's bundled native <select>
 * dropdown with a `<details>`-based popover that shows an SVG flag next
 * to each locale's native-name label.
 *
 * Why a custom component instead of emoji flags in `locale.label`?
 *   - Chrome + Firefox on Windows don't ship country-flag emoji glyphs;
 *     unicode 🇩🇪 etc. render as boxed letter pairs ("DE" in a box)
 *     instead of an actual flag.  SVG-via-component renders identically
 *     on every platform we ship.
 *
 * Why <details>/<summary>?
 *   - Native disclosure widget — open/close is browser-handled, no JS
 *     state needed.  Inline script below adds click-outside and Escape
 *     handling on top.
 *   - Keyboard-accessible by default (Enter on summary toggles).
 *   - Falls back gracefully if JS fails.
 *
 * Flag SVGs come from `country-flag-icons` (MIT-licensed, ~4 KB total
 * for the nine flags we use, tree-shaken from the package's full set).
 */
import config from 'virtual:starlight/user-config';

import GB from 'country-flag-icons/string/3x2/GB';
import DE from 'country-flag-icons/string/3x2/DE';
import ES from 'country-flag-icons/string/3x2/ES';
import FR from 'country-flag-icons/string/3x2/FR';
import JP from 'country-flag-icons/string/3x2/JP';
import KR from 'country-flag-icons/string/3x2/KR';
import BR from 'country-flag-icons/string/3x2/BR';
import RU from 'country-flag-icons/string/3x2/RU';
import CN from 'country-flag-icons/string/3x2/CN';

// Locale code → flag SVG (as raw string, rendered via set:html).
// `root` is English; convention in OSS docs is to use the UK flag for
// "the English language" rather than a region-specific (US) flag.
const FLAGS: Record<string, string> = {
  root:    GB,
  de:      DE,
  es:      ES,
  fr:      FR,
  ja:      JP,
  ko:      KR,
  'pt-BR': BR,
  ru:      RU,
  'zh-CN': CN,
};

// `Astro.locals.starlightRoute.locale` is `undefined` on root-locale
// pages.  Default to `'root'` to keep the lookup tables happy.
const route         = Astro.locals.starlightRoute;
const currentLocale = route?.locale ?? 'root';
const entries       = Object.entries(config.locales ?? {});
const currentLabel  = (config.locales as Record<string, { label: string } | undefined>)
  ?.[currentLocale]?.label ?? '';

// Translate the current page's pathname into the equivalent path for a
// different locale.  Strips any current locale prefix off `pathname`,
// then prepends the target locale (unless it's root).  Mirrors what
// Starlight's internal `localizedUrl` util does, but inlined so we
// don't depend on a non-public import path.
function localizedPathname(targetLocale: string): string {
  let pathname = Astro.url.pathname;
  const localeKeys = Object.keys(config.locales ?? {}).filter((k) => k !== 'root');
  for (const key of localeKeys) {
    if (pathname === `/${key}` || pathname === `/${key}/` || pathname.startsWith(`/${key}/`)) {
      pathname = pathname.slice(key.length + 1) || '/';
      break;
    }
  }
  if (targetLocale === 'root') return pathname;
  if (pathname === '/') return `/${targetLocale}/`;
  return `/${targetLocale}${pathname}`;
}

// i18n string for the accessible label (screen-reader announcement).
const accessibleLabel: string =
  (Astro.locals as { t?: (key: string) => string }).t?.('languageSelect.accessibleLabel') ??
  'Select language';
---

{
  config.isMultilingual && (
    <starlight-lang-select>
      <details class="lang-dropdown">
        <summary aria-label={accessibleLabel}>
          <span class="flag" set:html={FLAGS[currentLocale] ?? ''} />
          <span class="label">{currentLabel}</span>
          <svg
            class="caret"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="currentColor"
          >
            <path d="M16.59 8.59 12 13.17 7.41 8.59 6 10l6 6 6-6z" />
          </svg>
        </summary>
        <ul>
          {entries.map(([code, locale]) => (
            <li>
              <a
                href={localizedPathname(code)}
                aria-current={code === currentLocale ? 'true' : undefined}
              >
                <span class="flag" set:html={FLAGS[code] ?? ''} />
                <span class="label">{locale!.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </details>
    </starlight-lang-select>
  )
}

<script>
  // Native <details> handles open/close on summary click.  We layer on
  // (1) click-outside-to-close and (2) Escape-to-close, both of which
  // are conventional for dropdown menus and absent from the native
  // disclosure widget.
  class StarlightLanguageSelect extends HTMLElement {
    constructor() {
      super();
      const details = this.querySelector('details');
      if (!details) return;
      const summary = details.querySelector('summary');

      document.addEventListener('click', (e) => {
        if (!details.open) return;
        if (e.target instanceof Node && !details.contains(e.target)) {
          details.open = false;
        }
      });

      details.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && details.open) {
          e.preventDefault();
          details.open = false;
          if (summary instanceof HTMLElement) summary.focus();
        }
      });
    }
  }
  customElements.define('starlight-lang-select', StarlightLanguageSelect);
</script>

<style>
  /* Scope everything to the custom element so we don't bleed into the
   * theme dropdown which lives next door in the header. */
  starlight-lang-select {
    display: inline-flex;
    position: relative;
  }

  .lang-dropdown {
    position: relative;
  }

  summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding-block: 0.5rem;
    padding-inline: 0.5rem;
    color: var(--sl-color-gray-2);
    border-radius: 0.25rem;
    font-size: var(--sl-text-sm, 0.875rem);
    line-height: 1;
    user-select: none;
  }
  /* Hide the default disclosure triangle. */
  summary::-webkit-details-marker { display: none; }
  summary::marker              { content: ''; }

  summary:hover               { color: var(--sl-color-white); }
  details[open] > summary     { color: var(--sl-color-white); }
  summary:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  /* Caret rotates when the dropdown is open — small affordance that
   * the disclosure is interactive. */
  .caret {
    transition: transform 0.15s ease-out;
  }
  details[open] > summary .caret {
    transform: rotate(180deg);
  }

  /* The flag itself.  3:2 aspect ratio (matches the source SVGs).
   * `display: inline-flex` lets the inner SVG fill the container. */
  .flag {
    display: inline-flex;
    flex-shrink: 0;
    width: 1.5em;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    /* Subtle outline so light flags (Japan, Korea) stay visible
     * against the page background. */
    box-shadow: 0 0 0 1px rgb(0 0 0 / 0.15);
  }
  /* `set:html` injects the SVG as raw markup; size it to fill .flag. */
  .flag :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* The dropdown menu itself.  Positioned absolutely below the summary,
   * right-aligned so it can't overflow the viewport off-screen on the
   * header's right edge. */
  ul {
    position: absolute;
    top: calc(100% + 0.25rem);
    inset-inline-end: 0;
    min-width: max-content;
    margin: 0;
    padding-block: 0.25rem;
    padding-inline: 0;
    list-style: none;
    background: var(--sl-color-bg-nav, var(--sl-color-bg));
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.25);
    z-index: 100;
  }

  ul li { margin: 0; }

  ul a {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding-block: 0.5rem;
    padding-inline: 0.875rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    white-space: nowrap;
    font-size: var(--sl-text-sm, 0.875rem);
    line-height: 1.2;
  }
  ul a:hover,
  ul a:focus-visible {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    outline: none;
  }
  ul a[aria-current='true'] {
    color: var(--sl-color-accent-high);
    font-weight: 600;
    background: var(--sl-color-accent-low);
  }
</style>
